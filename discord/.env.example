# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# LLM Provider: zo, openai, anthropic, or openrouter
LLM_PROVIDER=zo

# Zo Computer API (recommended - uses your Zo account)
ZO_API_KEY=your_zo_api_key_here

# Alternative LLM Providers (uncomment one section)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# Optional Configuration
DEFAULT_MODEL=vercel:moonshotai/kimi-k2.5
MAX_HISTORY=10
SYSTEM_PROMPT=You are a helpful Discord assistant. Be friendly, concise, and engaging.